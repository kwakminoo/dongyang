{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Compile & Run Java (출력만 표시)",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy", "Bypass",
				"-File", "${workspaceFolder}/run-current.ps1",
				"-SrcFile", "${file}"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"group": { "kind": "build", "isDefault": true },
			"presentation": {
				"echo": false,
				"reveal": "always",
				"focus": true,
				"panel": "dedicated",
				"showReuseMessage": false,
				"clear": true
			},
			"problemMatcher": ["$javac"]
		}
	]
}
